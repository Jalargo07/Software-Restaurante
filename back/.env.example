# ==========================================
# CONFIGURACIÓN GENERAL
# ==========================================
PORT=3000
JWT_SECRET=restaurant_secret_key_2026
CORS_ORIGIN=http://localhost:5173

# ==========================================
# BASE DE DATOS
# ==========================================
# Desarrollo Local (SQLite)
DB_DIALECT=sqlite
# Producción Cloud (PostgreSQL)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=restaurantedb
# DB_USER=postgres
# DB_PASSWORD=postgres

# ==========================================
# ALMACENAMIENTO S3 / COMPATIBLE S3
# ==========================================
# 1. Desarrollo Local (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=alejoadmin
S3_SECRET_ACCESS_KEY=alejo1234
S3_BUCKET_NAME=restaurante-bucket
S3_FORCE_PATH_STYLE=true

# 2. Producción Cloud (Cloudflare R2 / Supabase / AWS S3)
# - Cloudflare R2 Endpoint: https://<account_id>.r2.cloudflarestorage.com
# - S3_FORCE_PATH_STYLE=false para Cloudflare R2 / AWS S3 / Supabase
# S3_ENDPOINT=https://tu-account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=tu_access_key_id
# S3_SECRET_ACCESS_KEY=tu_secret_access_key
# S3_BUCKET_NAME=tu-bucket
# S3_FORCE_PATH_STYLE=false
